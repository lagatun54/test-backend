{
  "openapi": "3.0.3",
  "info": {
    "title": "Mock Backend API",
    "description": "Минимальный mock API на PHP 8",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Текущий хост"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "description": "Проверка, что сервер работает",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Сервер в порядке",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "status": "ok",
                  "php": "8.3.0",
                  "time": "2026-06-10T12:00:00+00:00"
                }
              }
            }
          }
        }
      }
    },
    "/api/items": {
      "get": {
        "tags": ["Items"],
        "summary": "Список элементов",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "Список всех элементов",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Items"],
        "summary": "Создать элемент",
        "operationId": "createItem",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateItemRequest"
              },
              "example": {
                "title": "Новый элемент",
                "description": "Описание"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Элемент создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemResponse"
                }
              }
            }
          },
          "422": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Field \"title\" is required"
                }
              }
            }
          }
        }
      }
    },
    "/api/items/{id}": {
      "get": {
        "tags": ["Items"],
        "summary": "Получить элемент по ID",
        "operationId": "getItem",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Элемент найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemResponse"
                }
              }
            }
          },
          "404": {
            "description": "Элемент не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Item not found"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "required": ["id", "title", "description"],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Первый элемент"
          },
          "description": {
            "type": "string",
            "example": "Пример записи"
          }
        }
      },
      "CreateItemRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Новый элемент"
          },
          "description": {
            "type": "string",
            "example": "Описание"
          }
        }
      },
      "ItemResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Item"
          }
        }
      },
      "ItemListResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "php", "time"],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "php": {
            "type": "string",
            "example": "8.3.0"
          },
          "time": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
